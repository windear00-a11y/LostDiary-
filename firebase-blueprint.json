{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with pen name for the public library",
      "type": "object",
      "properties": {
        "display_name": { "type": "string" },
        "pen_name": { "type": "string" },
        "bio": { "type": "string" },
        "avatar_url": { "type": "string" },
        "pen_name_tag": { "type": "string" },
        "intelligence_profile": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["pen_name", "created_at"]
    },
    "Message": {
      "title": "Message",
      "description": "Private chat message between user and AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai", "diary"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string" }
      },
      "required": ["userId", "content", "created_at"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter in the user's autobiography",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "volume_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    },
    "LibraryStory": {
      "title": "LibraryStory",
      "description": "Publicly published story (Sealed Version)",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "story_content": { "type": "string" },
        "pen_name": { "type": "string" },
        "pen_name_tag": { "type": "string" },
        "dominant_emotion": { "type": "string" },
        "likes_count": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "story_content"]
    },
    "BridgeMessage": {
      "title": "BridgeMessage",
      "description": "Transient message between two users on a bridge",
      "type": "object",
      "properties": {
        "bridgeId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["bridgeId", "senderId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User's private profile and public identity"
    },
    "/messages/{msgId}": {
      "schema": "Message",
      "description": "Private Chat logs"
    },
    "/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Automated life chapters"
    },
    "/library/{storyId}": {
      "schema": "LibraryStory",
      "description": "Public anonymous stories"
    },
    "/bridges/{bridgeId}/messages/{msgId}": {
      "schema": "BridgeMessage",
      "description": "Messages on a specific bridge connection"
    }
  }
}
